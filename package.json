{
  "name": "unused",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:ext": "npm run build -w apps/vscode-extension",
    "package:ext": "npm run vsce:pack -w apps/vscode-extension",
    "pack": "npm run build:ext && npm run package:ext",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "turbo": "latest",
    "typescript": "latest",
    "vitest": "^4.1.7"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "1.0.2"
  }
}
